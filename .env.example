# Neon (serverless Postgres) connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Secret used to sign login tokens (use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Email sending (Resend). If RESEND_API_KEY is unset, invites fall back to a copyable link.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Ayanu <notify@ayanu.sixma.jp>

# Public base URL, used to build invite links inside emails (e.g. https://ayanu.sixma.jp).
# Optional — falls back to the request origin when unset.
APP_URL=https://ayanu.sixma.jp

# Social login (optional). A provider's button appears only when BOTH its id and
# secret are set. Register each provider's redirect URI as:
#   <APP_URL>/api/auth/oauth/google/callback
#   <APP_URL>/api/auth/oauth/github/callback
# (also add the localhost variant, e.g. http://localhost:3000/api/auth/oauth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
